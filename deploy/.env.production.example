# Production environment TEMPLATE for the VPS docker compose stack.
#
# SAFE TO COMMIT — placeholders only. Never put real passwords/tokens here.
#
# On the VPS only:
#   cp .env.production.example .env && nano .env
#
# Real secrets live in:
#   - VPS file: /opt/elevate/.env  (never git-tracked)
#   - GitHub: Settings → Secrets and variables → Actions
#
# Compile-time NEXT_PUBLIC_* values are baked into the frontend image in CI
# (GitHub repo Variables), not in this file. For an IP-only deploy set the
# GitHub Variables to:
#   NEXT_PUBLIC_API_URL  = http://206.162.244.11:8080/api/v1
#   NEXT_PUBLIC_SITE_URL = http://206.162.244.11:8080

# --- Container images (Docker Hub) -----------------------------------------
# Docker Hub username/namespace that owns the images (e.g. "reazulislamreaz").
# Images are published as <IMAGE_OWNER>/elevate-backend and .../elevate-frontend.
IMAGE_OWNER=your-dockerhub-username
# Image tag to run. The deploy workflow overrides this per release; keep "latest"
# as the fallback for manual `docker compose` commands.
IMAGE_TAG=latest

# --- Public address ---------------------------------------------------------
# No domain: the stack is served over plain HTTP on the VPS IP. Host port 8080
# is used because the VPS already runs another nginx on :80/:443.
# Everything (storefront + /api + /uploads) shares this single origin.
PUBLIC_URL=http://206.162.244.11:8080

# --- Database (postgres service) -------------------------------------------
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me-strong-db-password
# Points at the compose "postgres" service. Keep host/db/user in sync with the
# POSTGRES_* values above.
DATABASE_URL=postgresql://ecommerce:change-me-strong-db-password@postgres:5432/ecommerce?schema=public

# --- Redis (redis service) --------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Auth secrets (min 32 chars each) --------------------------------------
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-32chars

# --- CORS -------------------------------------------------------------------
# Must match the storefront's public origin (PUBLIC_URL above).
FRONTEND_ORIGIN=http://206.162.244.11:8080

# --- Cookies ----------------------------------------------------------------
# MUST be false over plain HTTP, or browsers drop the auth/guest-cart cookies
# and login/checkout break. Set to true only once the site is behind HTTPS.
COOKIE_SECURE=false

# --- SMTP (required in production) -----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
MAIL_FROM="Elevate Apparel <you@gmail.com>"
CONTACT_INBOX=

# --- Business config --------------------------------------------------------
CRM_HIGH_VALUE_THRESHOLD_POISHA=1000000

# --- Database seed (optional; never runs during normal deploy) -------------
# Production migrate only applies schema. To seed once on the VPS:
#   ENABLE_PRODUCTION_SEED=true
#   SEED_SUPER_ADMIN_EMAIL=...
#   SEED_SUPER_ADMIN_PASSWORD=...
#   SEED_SUPER_ADMIN_PHONE=...
#   docker compose --env-file .env -f docker-compose.prod.yml --profile seed run --rm seed
# Then set ENABLE_PRODUCTION_SEED=false again.
ENABLE_PRODUCTION_SEED=false
# SEED_PROFILE=full
# SEED_COMMERCE_DEMO=true
# SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
# SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password-12+chars
# SEED_SUPER_ADMIN_PHONE=01700000000
# SEED_ADMIN_EMAIL=admin@elevateapparel.demo
# SEED_ADMIN_PASSWORD=AdminDemoPass123
# SEED_ADMIN_PHONE=01710000002
# SEED_DEMO_PASSWORD=CustomerDemoPass123
