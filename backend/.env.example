NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-at-least-32-characters
FRONTEND_ORIGIN=http://localhost:3000
# Marks auth/guest-cart cookies as Secure. Defaults to true in production and
# false otherwise; set to false when serving production over plain HTTP.
# COOKIE_SECURE=false
# Database seed (`npm run prisma:seed` / `prisma:migrate-and-seed`).
# Deploy runs seed after migrate by default. Disable with:
#   ENABLE_PRODUCTION_SEED=false   # when NODE_ENV=production
#   SEED_ENABLED=false             # any environment
# SEED_PROFILE=full          # full | core (core = users/catalog/coupons/banners only)
# SEED_COMMERCE_DEMO=true    # set false to skip carts/orders/CRM demo graph
SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password-12+chars
SEED_SUPER_ADMIN_PHONE=01700000000
SEED_ADMIN_EMAIL=admin@elevateapparel.demo
SEED_ADMIN_PASSWORD=AdminDemoPass123
SEED_ADMIN_PHONE=01710000002
SEED_DEMO_PASSWORD=CustomerDemoPass123

# SMTP delivery for transactional email (queued via BullMQ).
# For Gmail use an App Password (Google Account -> Security -> App passwords).
# Leave SMTP_USER/SMTP_PASSWORD unset in development to log emails instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
MAIL_FROM="Elevate Apparel <you@gmail.com>"

# Local product image storage (admin uploads). Served at /uploads/products.
# Defaults to backend/uploads/products when unset.
# PRODUCT_UPLOAD_DIR=./uploads/products

# Local report export storage (CSV/XLSX, expires after 24 hours).
# REPORTS_STORAGE_DIR=./storage/reports

# CRM high-value customer lifetime threshold in poisha (default ৳10,000 = 1_000_000).
# CRM_HIGH_VALUE_THRESHOLD_POISHA=1000000

