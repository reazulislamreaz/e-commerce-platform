NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-at-least-32-characters
FRONTEND_ORIGIN=http://localhost:3000
# Used only by `npm run prisma:seed` to create the single Super Admin account
SEED_SUPER_ADMIN_EMAIL=superadmin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password-12+chars
SEED_SUPER_ADMIN_PHONE=01700000000

# SMTP delivery for transactional email (queued via BullMQ).
# For Gmail use an App Password (Google Account -> Security -> App passwords).
# Leave SMTP_USER/SMTP_PASSWORD unset in development to log emails instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
MAIL_FROM="Elevate Apparel <you@gmail.com>"

