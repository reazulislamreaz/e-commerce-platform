generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  /// Bangladeshi mobile number stored in E.164 format (+8801XXXXXXXXX)
  phone           String     @unique
  passwordHash    String
  role            Role       @default(CUSTOMER)
  status          UserStatus @default(PENDING_VERIFICATION)
  firstName       String?
  lastName        String?
  emailVerifiedAt DateTime?  @db.Timestamptz(3)
  deletedAt       DateTime?  @db.Timestamptz(3)
  createdAt       DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @db.Timestamptz(3)

  sessions           AuthSession[]
  verificationTokens VerificationToken[]

  @@index([role, status])
  @@index([createdAt])
}

/// Single-use, expiring tokens for email verification (and future flows such
/// as password reset). Only a SHA-256 hash of the raw token is stored.
model VerificationToken {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @db.Uuid
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime              @db.Timestamptz(3)
  usedAt    DateTime?             @db.Timestamptz(3)
  createdAt DateTime              @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("verification_token")
}

/// One row per login (device/browser). Revoking a session invalidates
/// every refresh token that belongs to it.
model AuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  ip         String?
  userAgent  String?
  expiresAt  DateTime  @db.Timestamptz(3)
  lastSeenAt DateTime  @default(now()) @db.Timestamptz(3)
  revokedAt  DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("auth_session")
}

/// Rotating refresh tokens. `tokenHash` is an HMAC-SHA256 of the opaque
/// cookie value so tokens can be looked up by exact hash. Reuse of a
/// consumed token revokes the whole `familyId`.
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @db.Uuid
  tokenHash    String    @unique
  familyId     String    @db.Uuid
  expiresAt    DateTime  @db.Timestamptz(3)
  usedAt       DateTime? @db.Timestamptz(3)
  revokedAt    DateTime? @db.Timestamptz(3)
  replacedById String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)

  session AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([familyId])
  @@map("refresh_token")
}
